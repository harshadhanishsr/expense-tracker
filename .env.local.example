# .env.local.example

# Supabase project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Server-only keys — NO NEXT_PUBLIC_ prefix (never exposed to browser)
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cookie signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=at-least-32-random-characters-here
